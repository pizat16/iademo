<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CENTINELL AI FORCE — V2.5 LIGHT BLUE</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@300;400;500;600;700&family=Share+Tech+Mono&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}

:root{
  /* PALETA AZUL ACLARADA */
  --bg0:#05111d;      /* Fondo base más profundo */
  --bg1:#0b1e33;      /* Paneles */
  --bg2:#142d4c;      /* Tarjetas */
  --bg3:#1e3e66;      /* Resaltados */
  
  --cyan:#a1eaff;     /* CIAN HIELO (Más claro) */
  --cyan-dim:rgba(161, 234, 255, 0.12);
  --cyan-b:rgba(161, 234, 255, 0.3);
  
  --green:#70ffdb;    /* Verde aguamarina */
  --green-dim:rgba(112, 255, 219, 0.1);
  --amber:#ffdb70;
  --amber-dim:rgba(255, 219, 112, 0.12);
  --red:#ff708b;
  --red-dim:rgba(255, 112, 139, 0.12);
  
  --txt:#f0f8ff;      /* Blanco azulado */
  --txt2:#a5c5e0;     /* Azul grisáceo claro */
  --txt3:#628bb3;     /* Azul sombra */
  
  --fh:'Rajdhani',sans-serif;
  --fm:'Share Tech Mono',monospace;
  --hl:1px solid rgba(161, 234, 255, 0.25);
}

html,body{height:100%;overflow:hidden;background:var(--bg0);color:var(--txt);font-family:var(--fm);}

/* BG CANVAS */
#bgc{position:fixed;inset:0;z-index:0;pointer-events:none;}
.scanline{position:fixed;inset:0;z-index:1;pointer-events:none;background:linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.1) 50%), linear-gradient(90deg, rgba(255, 0, 0, 0.02), rgba(0, 255, 0, 0.01), rgba(0, 0, 255, 0.02));background-size: 100% 4px, 3px 100%;}

/* VISTAS */
.view{position:fixed;inset:0;z-index:10;display:none;overflow:hidden;}
.view.active{display:flex;flex-direction:column;}

/* LOGIN */
#view-login{align-items:center;justify-content:center;gap:32px;padding:30px 20px;}
.logo-main{font-family:var(--fh);font-size:62px;font-weight:700;letter-spacing:14px;color:var(--cyan);text-shadow:0 0 30px var(--cyan-dim);line-height:1;}
.logo-sub{font-size:11px;letter-spacing:6px;color:var(--txt2);margin-top:8px;text-transform:uppercase;}

/* GRILLA DE OPERADORES */
.ugrid{display:grid;grid-template-columns:repeat(5,1fr);gap:12px;max-width:900px;width:100%;}
.utile{background:var(--bg2);border:var(--hl);padding:15px;cursor:pointer;transition:all .3s;text-align:center;clip-path:polygon(0 0,calc(100% - 10px) 0,100% 10px,100% 100%,10px 100%,0 calc(100% - 10px));}
.utile:hover{background:var(--bg3);border-color:var(--cyan);transform:translateY(-3px);box-shadow: 0 0 20px var(--cyan-dim);}
.utile .av{width:40px;height:40px;background:var(--cyan-dim);border:1px solid var(--cyan-b);display:flex;align-items:center;justify-content:center;font-family:var(--fh);font-size:14px;font-weight:700;color:var(--cyan);margin:0 auto 10px;}
.utile .tn{font-family:var(--fh);font-size:12px;font-weight:600;letter-spacing:1px;color:var(--txt);}

/* BOTONES */
.btn{background:transparent;border:1px solid var(--cyan);color:var(--cyan);font-family:var(--fh);font-size:14px;font-weight:600;letter-spacing:3px;padding:10px 25px;cursor:pointer;transition:0.3s;clip-path:polygon(10% 0, 100% 0, 100% 70%, 90% 100%, 0 100%, 0 30%);}
.btn:hover{background:var(--cyan);color:var(--bg0);box-shadow:0 0 15px var(--cyan);}

/* CHAT AREA */
#view-chat{flex-direction:row;}
.sidebar{width:260px;background:var(--bg1);border-right:var(--hl);padding:20px;display:flex;flex-direction:column;gap:20px;}
.chat-main{flex:1;display:flex;flex-direction:column;background:rgba(5, 17, 29, 0.7);}
#msgs{flex:1;overflow-y:auto;padding:25px;display:flex;flex-direction:column;gap:15px;}
.mbub{background:var(--bg2);border:var(--hl);padding:12px 16px;font-size:14px;color:var(--txt);border-radius:2px;border-left:3px solid var(--cyan);}

/* INPUT */
.cinput-area{padding:20px;background:var(--bg1);border-top:var(--hl);display:flex;gap:15px;}
textarea.min{flex:1;background:var(--bg0);border:var(--hl);color:var(--cyan);padding:12px;font-family:var(--fm);outline:none;resize:none;}
</style>
</head>
<body>

<canvas id="bgc"></canvas>
<div class="scanline"></div>

<div id="view-login" class="view active">
    <div style="text-align:center">
        <div class="logo-main">CENTINELL</div>
        <div class="logo-sub">AI FORCE MULTI-AGENT PLATFORM</div>
    </div>
    
    <div class="ugrid">
        <script>
            for(let i=1; i<=10; i++) {
                document.write(`
                    <div class="utile" onclick="alert('Iniciando Operador ${i}...')">
                        <div class="av">${i < 10 ? '0'+i : i}</div>
                        <div class="tn">OPERATOR-${i < 10 ? '0'+i : i}</div>
                        <div style="font-size:9px; color:var(--txt3)">STATUS: READY</div>
                    </div>
                `);
            }
        </script>
    </div>
    
    <button class="btn" onclick="document.getElementById('view-login').classList.remove('active'); document.getElementById('view-chat').classList.add('active');">ACCESO CENTRAL</button>
</div>

<div id="view-chat" class="view">
    <div class="sidebar">
        <div style="font-family:var(--fh); font-size:20px; color:var(--cyan); font-weight:700;">COMMAND CENTER</div>
        <div style="height:1px; background:var(--cyan-b);"></div>
        <div style="font-size:11px; color:var(--txt2);">ACTIVE AGENTS: 10</div>
        <div style="font-size:11px; color:var(--txt2);">THREAT LEVEL: LOW</div>
        <button class="btn" style="margin-top:auto; font-size:10px;" onclick="location.reload()">LOGOUT</button>
    </div>
    
    <div class="chat-main">
        <div id="msgs">
            <div class="mbub">SISTEMA EN LÍNEA: Esperando instrucciones del operador...</div>
        </div>
        
        <div class="cinput-area">
            <textarea class="min" placeholder="Escribe un comando o consulta..." rows="1"></textarea>
            <button class="btn">TRANSMITIR</button>
        </div>
    </div>
</div>

<script>
/* FONDO DINÁMICO REFINADO */
const canvas = document.getElementById('bgc');
const ctx = canvas.getContext('2d');
let w, h, particles = [];

function init() {
    w = canvas.width = window.innerWidth;
    h = canvas.height = window.innerHeight;
    particles = [];
    for(let i=0; i<60; i++) {
        particles.push({
            x: Math.random() * w,
            y: Math.random() * h,
            vx: (Math.random() - 0.5) * 0.5,
            vy: (Math.random() - 0.5) * 0.5,
            size: Math.random() * 2
        });
    }
}

function draw() {
    ctx.fillStyle = '#05111d';
    ctx.fillRect(0, 0, w, h);
    
    // Cuadrícula tenue
    ctx.strokeStyle = 'rgba(161, 234, 255, 0.05)';
    ctx.lineWidth = 1;
    for(let i=0; i<w; i+=50) { ctx.beginPath(); ctx.moveTo(i,0); ctx.lineTo(i,h); ctx.stroke(); }
    for(let i=0; i<h; i+=50) { ctx.beginPath(); ctx.moveTo(0,i); ctx.lineTo(w,i); ctx.stroke(); }

    ctx.fillStyle = '#a1eaff';
    particles.forEach(p => {
        p.x += p.vx;
        p.y += p.vy;
        if(p.x < 0 || p.x > w) p.vx *= -1;
        if(p.y < 0 || p.y > h) p.vy *= -1;
        ctx.beginPath();
        ctx.arc(p.x, p.y, p.size, 0, Math.PI*2);
        ctx.fill();
    });
    requestAnimationFrame(draw);
}

window.addEventListener('resize', init);
init();
draw();
</script>

</body>
</html>
